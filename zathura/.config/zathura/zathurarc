# -----------------------------------------------------------------------------
# CORE (important)
# -----------------------------------------------------------------------------
set selection-clipboard clipboard

# -----------------------------------------------------------------------------
# SCROLLING (Vim-style improvements)
# -----------------------------------------------------------------------------
map <C-d> scroll half-down
map <C-u> scroll half-up

map <C-f> scroll full-down
map <C-b> scroll full-up

# -----------------------------------------------------------------------------
# NAVIGATION (keep Vim mental model)
# -----------------------------------------------------------------------------
map gg goto top
map G goto bottom

# -----------------------------------------------------------------------------
# ZOOM (simple + predictable)
# -----------------------------------------------------------------------------
map z zoom in
map Z zoom out
map r zoom reset

# -----------------------------------------------------------------------------
# VIEW MODES (very useful for PDFs)
# -----------------------------------------------------------------------------
map f adjust_window best-fit
map w adjust_window width

# -----------------------------------------------------------------------------
# SEARCH (keep Vim consistency)
# -----------------------------------------------------------------------------
map n search next
map N search previous

# -----------------------------------------------------------------------------
# COPY
# -----------------------------------------------------------------------------
map y copy-selection

# -----------------------------------------------------------------------------
# RELOAD CONFIG
# -----------------------------------------------------------------------------
map R reload
